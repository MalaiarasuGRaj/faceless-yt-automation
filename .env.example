# ================================================
# YouTube Shorts Automation - Environment Variables
# ================================================
# Copy this file to .env and fill in your keys
# OR edit config/settings.py directly
#
# All APIs below are FREE tier

# Pexels (free stock footage)
# Get key: https://www.pexels.com/api/
PEXELS_API_KEY=YOUR_PEXELS_KEY

# Pixabay (backup stock footage + music)
# Get key: https://pixabay.com/api/docs/
PIXABAY_API_KEY=YOUR_PIXABAY_KEY

# Ollama runs locally - no key needed
# Install: https://ollama.com
# Then: ollama pull llama3

# YouTube API
# Setup: https://console.cloud.google.com
# Enable: YouTube Data API v3
# Create: OAuth 2.0 Client ID (Desktop app)
# Download client_secret.json → put in config/ folder
